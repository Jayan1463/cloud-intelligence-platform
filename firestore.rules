rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) &&
        get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid} {
      allow create, read, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow create: if isSignedIn();
      allow read: if isOrgMember(orgId);
      allow update, delete: if isOrgAdmin(orgId);

      match /members/{uid} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }

      match /invites/{inviteId} {
        allow read, write: if isOrgAdmin(orgId);
      }

      match /projects/{projectId} {
        allow read: if isOrgMember(orgId);
        allow create, update, delete: if isOrgAdmin(orgId);

        match /metrics/{metricId} {
          allow read: if isOrgMember(orgId);
          allow create: if isOrgMember(orgId);
          allow update, delete: if isOrgAdmin(orgId);
        }

        match /alerts/{alertId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }

        match /topology/{nodeId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }

        match /cost/{costId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgAdmin(orgId);
        }

        match /settings/{settingId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgAdmin(orgId);
        }
      }
    }
  }
}
